{
  "name": "@movie-challenge/api",
  "version": "1.0.0",
  "private": true,
  "description": "Backend da plataforma de filmes utilizando Fastify e Clean Architecture",
  "main": "build/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src --out-dir build",
    "start": "node build/server.js",
    "test": "vitest run --dir src/use-cases",
    "test:watch": "vitest --dir src/use-cases",
    "test:e2e": "vitest run --dir src/http",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@movie-challenge/eslint-config": "*",
    "@movie-challenge/ts-config": "*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.20",
    "prettier": "3.8.3",
    "prisma": "^5.22.0",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
