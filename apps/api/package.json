{
  "name": "@movie-challenge/api",
  "version": "1.0.0",
  "private": true,
  "description": "Backend da plataforma de filmes utilizando Fastify e Clean Architecture",
  "main": "build/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src --out-dir build",
    "start": "node build/server.js",
    "test": "vitest run src/use-cases",
    "test:watch": "vitest src/use-cases",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:e2e:watch": "vitest --config vitest.config.e2e.ts",
    "test:coverage": "vitest run --coverage",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:generate": "npx prisma generate",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1051.0",
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "10.0.0",
    "@fastify/swagger": "9.7.0",
    "@movie-challenge/core-types": "*",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@scalar/fastify-api-reference": "1.57.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "17.4.2",
    "fastify": "5.8.5",
    "fastify-print-routes": "5.0.1",
    "fastify-type-provider-zod": "6.1.0",
    "nodemailer": "8.0.7",
    "vitest": "4.1.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@movie-challenge/eslint-config": "*",
    "@movie-challenge/ts-config": "*",
    "@testcontainers/postgresql": "11.14.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "25.8.0",
    "@types/nodemailer": "8.0.0",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.6",
    "prettier": "3.8.3",
    "prisma": "^7.8.0",
    "supertest": "7.2.2",
    "testcontainers": "11.14.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest-tsconfig-paths": "3.4.1"
  }
}
